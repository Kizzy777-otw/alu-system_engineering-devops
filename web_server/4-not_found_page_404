#!/usr/bin/env bash
# Configure nginx with a custom 404 page

# 1. Install nginx
apt-get update -y
apt-get install -y nginx

# 2. Create the custom 404 page
echo "Ceci n'est pas une page" > /var/www/html/404.html

# 3. Update nginx default site to use custom 404
cat <<EOF > /etc/nginx/sites-available/default
server {
    listen 80 default_server;
    listen [::]:80 default_server;

    root /var/www/html;
    index index.nginx-debian.html;

    # Redirect /redirect_me (optional if you want to keep task 3)
    location /redirect_me {
        return 301 https://www.youtube.com/watch?v=QH2-TGUlwu4;
    }

    # Custom 404 page
    error_page 404 /404.html;

    location / {
        try_files \$uri \$uri/ =404;
    }
}
EOF

# 4. Restart nginx without systemctl
service nginx restart
